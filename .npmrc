node-linker=hoisted
save-exact=true
auto-install-peers=false
shamefully-hoist=false
ignore-scripts=true

# Supply-chain hardening: reject packages published less than 7 days ago.
# Defeats spray-and-pray malicious publish attacks that get taken down within hours.
# Exceptions below are for security-critical frameworks that ship urgent patches.
minimum-release-age=7
minimumReleaseAgeExclude[]=next
minimumReleaseAgeExclude[]=react
minimumReleaseAgeExclude[]=react-dom

# Strict engine checks — fail install if engines field doesn't match
engine-strict=true