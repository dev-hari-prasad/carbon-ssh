{
  "name": "carbon-ssh",
  "productName": "Carbon",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ],
    "overrides": {
      "postcss": "8.5.12",
      "tmp": ">=0.2.6",
      "axios": ">=1.16.0",
      "brace-expansion": ">=5.0.6",
      "ws": ">=8.20.1",
      "protobufjs": ">=7.5.8",
      "qs": ">=6.15.2"
    }
  },
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && tsx server.ts",
    "dev:electron": "node scripts/build-electron.mjs",
    "start:electron": "concurrently -k -n server,electron -c cyan,green \"tsx server.ts\" \"wait-on -t 60000 -i 3000 http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:electron": "node scripts/build-electron.mjs",
    "start": "next start",
    "lint": "next lint",
    "audit": "pnpm audit --audit-level=high",
    "audit:full": "pnpm audit --audit-level=moderate && pnpm licenses list",
    "verify:deps": "node scripts/verify-deps.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "sbom": "cdxgen -o sbom.json .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.98",
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/gateway": "^3.0.105",
    "@ai-sdk/openai": "^3.0.54",
    "@ai-sdk/openai-compatible": "^2.0.42",
    "@heroicons/react": "2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@ridemountainpig/svgl-react": "^1.0.16",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.83.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.170",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "corner-smoothing": "^0.1.5",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "hash-wasm": "4.12.0",
    "iconoir-react": "^7.11.0",
    "input-otp": "^1.4.2",
    "next": "16.2.6",
    "postcss": "^8.5.12",
    "posthog-js": "^1.372.9",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.5",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cyclonedx/cdxgen": "12.3.3",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.32.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ssh2": "1.15.5",
    "@types/ws": "8.18.1",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "26.8.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "png-to-ico": "3.0.1",
    "prettier": "^3.7.3",
    "sharp": "0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "3.2.4",
    "wait-on": "^9.0.5"
  }
}
